# Optional project root override
VIDEO_PRODUCTION_ROOT=/absolute/path/to/video-workshop

# Optional existing-series Day baseline
VIDEO_DIARY_START_DAY=1

# Optional rendering tool overrides
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
WHISPER_CPP_BIN=whisper-cli
WHISPER_CPP_MODEL=/absolute/path/to/ggml-base.bin
VIDEO_WORKSHOP_FONT=/absolute/path/to/CJK-font.ttc
NODE_BIN=node
CHROME_BIN=google-chrome

# Optional Feishu remote intake
FEISHU_BASE_TOKEN=
FEISHU_TABLE_ID=
FEISHU_SCRIPT_MODEL=
FEISHU_WORKER_INTERVAL_MS=30000
FEISHU_WORKER_LIMIT=100
CODEX_BIN=codex
