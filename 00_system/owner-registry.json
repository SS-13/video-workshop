{
  "schemaVersion": 1,
  "components": {
    "evolution-loop": {
      "agent": "system-steward-agent",
      "skill": "video-production-evolution",
      "commands": ["vp observe", "vp evolve"],
      "writeScope": [
        "00_state/observations",
        "00_state/evolution",
        "00_state/locks",
        "17_reports/evolution"
      ]
    },
    "release-gate": {
      "agent": "release-agent",
      "skill": "video-production-release",
      "commands": [
        "vp release status",
        "vp release canary-adopt",
        "vp release canary-check",
        "vp release readiness",
        "vp release activate",
        "vp release rollback",
        "vp run finalize-active"
      ],
      "writeScope": [
        "00_state/runs",
        "00_state/releases/<candidate>/canary",
        "00_system/releases/<candidate>/manifest.json",
        "17_reports/releases/<candidate>"
      ]
    },
    "cover-system": {
      "agent": "video-agent",
      "skill": "video-diary-cover",
      "commands": ["vp cover design", "vp cover make", "vp cover history"],
      "writeScope": [
        ".codex/skills/video-diary-cover/references/cover-routes.json",
        "04_videos/<date>/cover-qc",
        "05_exports/<date>",
        "15_cover_gallery"
      ]
    },
    "media-retention": {
      "agent": "system-steward-agent",
      "skill": "video-diary-cleanup",
      "commands": [
        "vp cleanup status",
        "vp cleanup configure",
        "vp cleanup run"
      ],
      "writeScope": [
        "00_state/workspace.json",
        "00_state/media-retention-ledger.csv",
        "03_recordings/<eligible-date>",
        "04_videos/<eligible-date>",
        "05_exports/<eligible-date>",
        "06_logs/media-retention"
      ]
    }
  }
}
